import java.util.Scanner;
import java.util.InputMismatchException;

public class Main {

    static String savedUsername = "";
    static String savedPassword = "";
    static String generatedRef = "";
    
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);

        while (true) {
            System.out.println("+------------------------------------------+");
            System.out.println("+       WELCOME TO GOVERNMENT INSPECT      +");
            System.out.println("+------------------------------------------+");

            System.out.println("1 - Register");
            System.out.println("2 - Login");
            System.out.print("Enter choice: ");

            int choice;
            try {
                choice = input.nextInt();
                input.nextLine(); 
            } catch (InputMismatchException e) {
                System.out.println("Invalid input!");
                input.nextLine(); 
                continue;
                
            }
            switch (choice) {
                case 1:
                    register(input);
                    break;
                case 2:
                    login(input);
                    break;
                default:
                    System.out.println("Invalid Choice only 1-2");
            }
        }
    }

    //+------------------------------------------------------+
    //                  | Registration | 
    //+------------------------------------------------------+
    public static void register(Scanner input) {
        System.out.println("=====[Gov.Registration]======");
        System.out.print("Create Username: ");
        savedUsername = input.nextLine();

        System.out.print("Create Password: ");
        savedPassword = input.nextLine();
      
        // REFERENCE SHAFT W3C
        generatedRef = "" + System.currentTimeMillis();
            System.out.println("Reference Number: " + generatedRef);

        System.out.println("Account Created Successfully!");
    }

    //+------------------------------------------------------+
    //                      | LOGIN | 
    //+------------------------------------------------------+
    public static void login(Scanner input) {
        System.out.print("Enter Username: ");
        String username = input.nextLine();

        System.out.print("Enter Password: ");
        String password = input.nextLine();

        if (savedUsername.isEmpty() || savedPassword.isEmpty()) {
            System.out.println("No existing account found. Please register first.");
            return;
        }
        if (!username.equals(savedUsername) || !password.equals(savedPassword)) {
            System.out.println("Invalid Login.");
            return;
        }

        System.out.println("Existing Save State Found.");
        System.out.println("Successful");

        selectIDCluster(input);
    }

    //+------------------------------------------------------+
    //              | ID Cluster Selection |
    //+------------------------------------------------------+
    public static void selectIDCluster(Scanner input) {
        System.out.println("===== Selection ID =====");
        System.out.println("(1) National Identification");
        System.out.println("(2) Health Identification");
        System.out.println("(3) Financial Identification");
        System.out.println("(4) Land Transportation Identification");
        System.out.println("(5) Barangay Identification");
        System.out.println("============================");
        System.out.print("Enter choice: ");

        int idChoice;
        try {
            idChoice = input.nextInt();
            input.nextLine();
        } catch (InputMismatchException e) {
            System.out.println("Invalid ID selection! Numbers only.");
            input.nextLine();
            return;
        }
        String userID = savedUsername;
        String refNum = generatedRef;
        UserID idObject;

        switch (idChoice) {
            case 1:
                NationalID nid = new NationalID();
                nid.username = userID;
                nid.referenceNumber = refNum;
                idObject = nid;
                break;
            case 2:
                HealthID hid = new HealthID();
                hid.username = userID;
                hid.referenceNumber = refNum;
                idObject = hid;
                break;
            case 3:
                FinancialID fid = new FinancialID();
                fid.username = userID;
                fid.referenceNumber = refNum;
                idObject = fid;
                break;
            case 4:
                LandTransportationID lid = new LandTransportationID();
                lid.username = userID;
                lid.referenceNumber = refNum;
                idObject = lid;
                break;
            case 5:
                BarangayID bid = new BarangayID();
                bid.username = userID;
                bid.referenceNumber = refNum;
                idObject = bid;
                break;
            default:
                System.out.println("Invalid ID.");
                return;
        } if (idObject.validateID()) {
            System.out.println("Process Complete.");
            idObject.displayIDinfo();
        } else {
            System.out.println("Validation Failed.");
        }
    }
}

//+------------------------------------------------------+
//                      | INTERFACE | 
//+------------------------------------------------------+
interface UserID { 
    void displayIDinfo();
    boolean validateID();
}

//+------------------------------------------------------+
//                      | BASE CLASS | 
//+------------------------------------------------------+
class IDCard {
    String username;
    String referenceNumber;
}

//+------------------------------------------------------+
//                  | National ID| 
//+------------------------------------------------------+
class NationalID extends IDCard implements UserID {
    @Override 
    public void displayIDinfo() {
        System.out.println("===== [NATIONAL ID] =====");
        System.out.println("Username: " + username);
        System.out.println("Reference Number: " + referenceNumber);
    }

    @Override
    public boolean validateID() {
        return true;
    }
}

